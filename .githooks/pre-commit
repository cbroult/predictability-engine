#!/bin/sh
set -e

# CI machine commits (auto-bump) skip this hook; Woodpecker sets CI=woodpecker
if [ -n "${CI:-}" ]; then
  exit 0
fi

echo "Pre-commit: Running RuboCop..."
bundle exec rubocop

echo "Pre-commit: Propagating versions to ERB-derived files..."
bundle exec rake version:propagate
git add .tool-versions .woodpecker/verify.yml

echo "Pre-commit: Generating sample reports..."
bundle exec rake reports:generate_samples
git add data/samples/reports/

if [ "${JIRA_ENV:-}" != "gha" ]; then
  echo "Pre-commit: Syncing CI badges in README..."
  bundle exec badge badges sync --org cbp-org --repo predictability-engine
  git add README.md
fi

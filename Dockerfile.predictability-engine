# Dockerfile.predictability-engine — lightweight image for CI predictability reports
#
# Pre-installs predictability-engine and the cbp-org root CA.
#
# Rebuild when:
#   - predictability-engine version changes
#   - cbp-org root CA rotates

FROM ruby:4.0.3-alpine

# CBP_ORG_CA_CERT_B64: base64-encoded cbp-org root CA certificate.
ARG CBP_ORG_CA_CERT_B64
# GEM_VERSION: optional pin for predictability-engine. Empty = install latest.
ARG GEM_VERSION=""

# Install CA cert into system trust store
RUN apk add --no-cache ca-certificates && \
    echo "${CBP_ORG_CA_CERT_B64}" | base64 -d \
      > /usr/local/share/ca-certificates/cbp-org-root-ca.crt && \
    update-ca-certificates

# Install predictability-engine (optionally pinned to ${GEM_VERSION}).
# build-base is required to compile native gem extensions (e.g. enumerable-statistics);
# it is removed after installation to keep the image lean.
RUN apk add --no-cache --virtual .build-deps build-base && \
    if [ -n "${GEM_VERSION}" ]; then \
      gem install predictability-engine --version "${GEM_VERSION}" \
        --source https://gems.cbp-org.internal --no-document; \
    else \
      gem install predictability-engine \
        --source https://gems.cbp-org.internal --no-document; \
    fi && \
    apk del .build-deps

# Entrypoint could be the engine itself
ENTRYPOINT ["predictability-engine"]

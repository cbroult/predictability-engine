# Dockerfile.ci — base CI image for predictability-engine workflows.
#
# Extends ruby:4.0.3 (Debian bookworm) with pre-installed system dependencies so
# CI steps skip the apt-get overhead on every run. Playwright Chromium is still
# downloaded at runtime by `predictability-engine setup` (it is runtime-version-pinned).
#
# Rebuild when: Ruby version changes, Node version changes, or system packages change.
# Push to docker-registry.cbp-org.internal/predictability-engine-ci:latest
# via scripts/build-ci-image.sh.
#
# Node version source: .tool-versions (nodejs <%= node_version %>)
# Regenerate this file from the template: bundle exec rake version:propagate

FROM ruby:4.0.3

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    rm -rf /var/lib/apt/lists/* && \
    curl -fsSL https://deb.nodesource.com/setup_<%= node_major %>.x | bash - && \
    apt-get install -y --no-install-recommends nodejs openssh-client && \
    rm -rf /var/lib/apt/lists/*

#!/usr/bin/env ruby
# frozen_string_literal: true

# Point bundler at this gem's Gemfile so the binary works from any CWD,
# not just when invoked via `bundle exec` from the project root.
ENV['BUNDLE_GEMFILE'] ||= File.expand_path('../Gemfile', __dir__)

begin
  require 'bundler/setup'
rescue LoadError
  # Bundler not available, hope for the best with system gems
end

$LOAD_PATH.unshift File.expand_path('../lib', __dir__)
require 'predictability_engine'
require 'predictability_engine/cli'

PredictabilityEngine::Cli.start(ARGV)

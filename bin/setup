#!/usr/bin/env bash
# bin/setup — Linux/macOS/CI bootstrap shim.
#
# Bootstraps bundler (needed before the CLI is available), then delegates to
# the cross-platform `predictability-engine setup` command which handles
# Playwright/Chromium. On Windows, run the equivalent directly:
#
#   gem install bundler && bundle install
#   bundle exec predictability-engine setup
#
# Environment variables:
#   SKIP_PLAYWRIGHT=1  — pass --skip-playwright to the PE command

set -euo pipefail
cd "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "==> Bootstrapping Bundler"
gem install bundler --conservative

playwright_flag=()
[ -n "${SKIP_PLAYWRIGHT:-}" ] && playwright_flag=(--skip-playwright)

bundle exec predictability-engine setup "${playwright_flag[@]}"

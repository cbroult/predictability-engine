#!/usr/bin/env bash
# bin/setup — Linux/macOS/CI bootstrap.
#
# Runs bundle install first (so the predictability-engine CLI becomes
# available), then delegates Playwright/Chromium installation to the CLI.
#
# On any platform you can also run each step individually:
#   gem install bundler && bundle install
#   bundle exec predictability-engine setup --skip-bundle
#
# Environment variables:
#   SKIP_PLAYWRIGHT=1  — pass --skip-playwright to the PE command

set -euo pipefail
cd "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "==> Bootstrapping Bundler"
gem install bundler --conservative

echo "==> Installing Ruby dependencies"
bundle install --jobs 4 --retry 3

playwright_flag=()
[ -n "${SKIP_PLAYWRIGHT:-}" ] && playwright_flag=(--skip-playwright)

bundle exec predictability-engine setup --skip-bundle "${playwright_flag[@]}"

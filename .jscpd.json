{
  "threshold": 0.8,
  "minLines": 2,
  "minTokens": 16,
  "reporters": [
    "console",
    "html"
  ],
  "ignore": [
    "coverage/**",
    "node_modules/**",
    "tmp/**",
    "report/**",
    "doc/**",
    "*.html",
    ".output.txt",
    ".woodpecker/**",
    ".idea/**"
  ],
  "absolute": true
}

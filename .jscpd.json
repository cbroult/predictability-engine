{
  "threshold": 0.8,
  "minLines": 3,
  "minTokens": 30,
  "reporters": [
    "html",
    "console"
  ],
  "ignore": [
    "vendor/**",
    "report/**",
    "reports/**",
    "**/reports/**",
    "tmp/**",
    "node_modules/**",
    "coverage/**",
    "doc/**",
    "bin/**",
    "package-lock.json",
    "package.json",
    "Gemfile.lock",
    ".woodpecker/**",
    ".playwright-mcp/**",
    ".background_output_*.txt",
    ".output.txt",
    ".idea/**",
    "report/**"
  ],
  "absolute": true
}
